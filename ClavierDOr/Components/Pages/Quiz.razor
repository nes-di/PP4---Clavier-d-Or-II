@page "/quiz"
@rendermode InteractiveServer

@inject ClavierDOr.Services.GameService GameService
@inject ClavierDOr.Services.PdfService PdfService
@inject NavigationManager NavManager

<PageTitle>Quizz - Le Clavier d'Or</PageTitle>

<div class="container mt-4">
    @if (GameService.JoueurActuel == null)
    {
        <div class="alert alert-warning shadow text-center">
            <p class="fs-4">⚠️ Aucune partie en cours.</p>
            <p>Veuillez démarrer une partie depuis l'accueil pour jouer.</p>
            <button class="btn btn-primary rounded-pill px-4" @onclick='() => NavManager.NavigateTo("/")'>Retour à l'accueil</button>
        </div>
    }
    else if (GameService.PartieTerminee)
    {
        <div class="alert @(GameService.APerdu ? "alert-danger border-danger" : "alert-success border-success") text-center shadow p-5 rounded-4 animate__animated animate__zoomIn">
            @if (GameService.APerdu)
            {
                <h1 class="display-4 fw-bold text-danger">💀 DÉFAITE...</h1>
                <p class="fs-4 mt-3">Dommage ! Le code a eu raison de vous cette fois-ci.</p>
            }
            else
            {
                <h1 class="display-4 fw-bold text-success">🏆 VICTOIRE !</h1>
                <p class="fs-4 mt-3">Félicitations ! Vous avez terrassé le Boss et conquis le Clavier d'Or.</p>
            }
            
            <h3 class="mt-3">Score final : <span class="badge bg-primary">@GameService.ScoreActuel points</span></h3>
            <p class="fs-4 mt-3">@GameService.MessageAction</p>
            
            <hr class="my-4" />

            @if (!GameService.APerdu)
            {
                <div class="mt-4">
                    <h5 class="mb-3 text-muted">Bravo ! Récupérez votre récompense :</h5>
                    <a href="@GetPdfDataUrl()" download="Certificat_@(GameService.JoueurActuel.Pseudo).pdf" class="btn btn-success btn-lg mx-2 shadow rounded-pill px-4">
                        📄 Télécharger mon certificat (PDF)
                    </a>
                </div>
            }

            <div class="mt-4">
                <button class="btn btn-outline-primary btn-lg mx-2 rounded-pill px-4" @onclick='() => NavManager.NavigateTo("/")'>
                    🏠 Retour à l'accueil
                </button>
            </div>
        </div>
    }
    else if (GameService.QuestionEnCours != null)
    {
        <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
            <div>
                <p class="text-muted mb-0 small text-uppercase fw-bold">Joueur en lice</p>
                <h3 class="text-primary mb-0">@GameService.JoueurActuel.Pseudo</h3>
            </div>
            <div class="text-center">
                <p class="text-muted mb-0 small text-uppercase fw-bold">Progression</p>
                <h4 class="mb-0">Question <span class="text-primary">@GameService.NumeroQuestion</span> / @GameService.TotalQuestions</h4>
            </div>
            <div class="text-end">
                <p class="text-muted mb-0 small text-uppercase fw-bold">Score Actuel</p>
                <h3 class="badge bg-success fs-4 mb-0">@GameService.ScoreActuel pts</h3>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(GameService.MessageAction))
        {
            <div class="alert alert-info shadow-sm border-0 rounded-3 mb-4 animate__animated animate__fadeIn">
                <strong>📢 @GameService.MessageAction</strong>
            </div>
        }

        <div class="card shadow-lg mb-4 border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-dark text-white p-3 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-tag-fill me-2"></i>Thème : <strong>@GameService.QuestionEnCours.Theme</strong></span>
                @if(GameService.QuestionEnCours.EstBoss) {
                    <span class="badge bg-danger p-2 px-3 border border-light animate__animated animate__pulse animate__infinite">👿 BOSS FINAL (POINTS x3)</span>
                }
            </div>
            <div class="card-body p-5">
                <h2 class="card-title text-center mb-5 fw-bold text-dark">@GameService.QuestionEnCours.Texte</h2>

                <div class="d-grid gap-3">
                    @foreach (var lettre in new[] { "A", "Z", "E", "R" })
                    {
                        var texteOption = lettre switch {
                            "A" => GameService.QuestionEnCours.OptionA,
                            "Z" => GameService.QuestionEnCours.OptionZ,
                            "E" => GameService.QuestionEnCours.OptionE,
                            "R" => GameService.QuestionEnCours.OptionR,
                            _ => ""
                        };

                        @if (!GameService.OptionsMasquees.Contains(lettre))
                        {
                            <button class="btn @GetButtonClass(lettre) btn-lg text-start py-3 shadow-sm transition-all fw-bold"
                                    disabled="@isProcessing"
                                    @onclick='() => Repondre(lettre)'>
                                <span class="badge bg-dark me-3 px-3">@lettre</span> @texteOption
                            </button>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="card bg-white border-0 shadow-sm rounded-4 mb-5">
            <div class="card-body d-flex justify-content-between align-items-center p-4">
                <div class="d-flex align-items-center">
                    <div class="bg-warning-subtle p-3 rounded-circle me-3">
                        <span class="fs-2">👤</span>
                    </div>
                    <div>
                        <h5 class="mb-0 text-dark fw-bold">Rôle : @GameService.RoleActuel?.Nom</h5>
                        <p class="mb-0 text-muted small">@GameService.RoleActuel?.Description</p>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-3">
                    @if (GameService.RoleActuel is ClavierDOr.Models.Roles.DeveloppeurBack)
                    {
                        <span class="badge bg-info p-3 fs-6 shadow-sm rounded-pill text-dark">
                            🛡️ PROTECTION ACTIVE
                        </span>
                    }
                    else
                    {
                        <button class="btn btn-warning btn-lg fw-bold shadow rounded-pill px-4"
                                disabled="@(GameService.RoleActuel?.PouvoirUtilise == true || isProcessing)"
                                @onclick="UtiliserPouvoir">
                            ⚡ @(GameService.RoleActuel?.PouvoirUtilise == true ? "POUVOIR UTILISÉ" : "ACTIVER MON POUVOIR")
                        </button>
                    }

                    <button class="btn btn-light border btn-sm rounded-pill px-3" disabled="@isProcessing" @onclick="Sauvegarder">
                        💾 Sauvegarder
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .transition-all { transition: all 0.2s ease-in-out; }
    .btn-outline-dark:hover { transform: translateX(10px); background-color: #f8f9fa; color: #212529; }
</style>

@code {
    private bool isProcessing = false;

    private async Task Repondre(string lettre)
    {
        if (isProcessing) return;
        isProcessing = true;

        GameService.VerifierReponse(lettre);
        StateHasChanged();
        await Task.Delay(1000);

        if (!GameService.PartieTerminee)
        {
            GameService.ChargerNouvelleQuestion();
        }

        isProcessing = false;
        StateHasChanged();
    }

    private string GetButtonClass(string lettre)
    {
        if (GameService.LettreSelectionnee != lettre) return "btn-outline-dark";
        return GameService.DerniereReponseCorrecte == true ? "btn-success text-white" : "btn-danger text-white";
    }

    private void UtiliserPouvoir()
    {
        GameService.UtiliserPouvoir();
    }

    private void Sauvegarder()
    {
        GameService.SauvegarderPartieEnCours();
        NavManager.NavigateTo("/historique");
    }

    private string GetPdfDataUrl()
    {
        if (GameService.JoueurActuel == null || GameService.RoleActuel == null) return "#";

        var pdfBytes = PdfService.GenererCertificat(
            GameService.JoueurActuel.Pseudo, 
            GameService.RoleActuel.Nom, 
            GameService.ScoreActuel
        );
        
        var base64Pdf = Convert.ToBase64String(pdfBytes);
        return $"data:application/pdf;base64,{base64Pdf}";
    }
}