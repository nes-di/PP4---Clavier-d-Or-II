@page "/"
@rendermode InteractiveServer
@inject ClavierDOr.Services.GameService GameService
@inject NavigationManager NavManager

<PageTitle>Accueil - Le Clavier d'Or</PageTitle>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold text-primary">Le Clavier d'Or</h1>
        <p class="text-muted fs-5">L'aventure dont vous êtes le développeur.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg p-4 p-md-5 bg-white rounded-4">
                
                <section class="mb-5">
                    <h4 class="fw-bold mb-3"><span class="badge bg-primary me-2">1</span> Qui êtes-vous ?</h4>
                    <input @bind="pseudo" @bind:event="oninput" class="form-control form-control-lg border-2" placeholder="Votre pseudo..." />
                </section>

                <section class="mb-5">
                    <h4 class="fw-bold mb-3"><span class="badge bg-primary me-2">2</span> Choisissez votre spécialité</h4>
                    <div class="row g-3">
                        @foreach (var r in roles)
                        {
                            <div class="col-md-4">
                                <div class="card h-100 role-card @(role == r.Key ? "active-role" : "")" @onclick="() => role = r.Key">
                                    <div class="card-body text-center">
                                        <div class="fs-1 mb-2">@r.Value.Icon</div>
                                        <h6 class="fw-bold">@r.Value.Label</h6>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">@r.Value.Desc</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <section class="mb-5">
                    <h4 class="fw-bold mb-3"><span class="badge bg-primary me-2">3</span> Choisissez votre domaine</h4>
                    <div class="d-flex flex-wrap gap-2">
                        @if (themesDisponibles.Any())
                        {
                            @foreach (var t in themesDisponibles)
                            {
                                <button class="btn @(theme == t ? "btn-primary" : "btn-outline-primary") px-4 py-2 rounded-pill"
                                        @onclick="() => theme = t">
                                    @t
                                </button>
                            }
                        }
                        else
                        {
                            <p class="text-danger small italic">Chargement des thèmes (ou base vide)...</p>
                        }
                    </div>
                </section>

                <div class="text-center mt-4">
                    <button class="btn btn-primary btn-xl px-5 py-3 fw-bold shadow-sm @(PeutLancer ? "" : "disabled")" 
                            @onclick="LancerJeu">
                        LANCER LE DÉFI 🚀
                    </button>
                    @if (!PeutLancer) {
                        <p class="text-muted mt-2 small">Remplissez tous les champs pour commencer</p>
                    }
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .role-card { cursor: pointer; transition: all 0.2s ease; border: 2px solid #eee; }
    .role-card:hover { border-color: #0d6efd; background-color: #f8f9ff; transform: translateY(-3px); }
    .active-role { border-color: #0d6efd !important; background-color: #eef4ff !important; box-shadow: 0 4px 15px rgba(13, 110, 253, 0.2); }
    .btn-xl { font-size: 1.25rem; border-radius: 50px; }
</style>

@code {
    private string pseudo = "";
    private string role = "Front";
    private string theme = "";
    private List<string> themesDisponibles = new();

    private Dictionary<string, (string Label, string Icon, string Desc)> roles = new()
    {
        { "Front", ("Front-End", "🎨", "Pouvoir : Passer une question") },
        { "Back", ("Back-End", "⚙️", "Pouvoir : 2ème essai auto") },
        { "Mobile", ("Mobile", "📱", "Pouvoir : Indice (50/50)") }
    };

    private bool PeutLancer => !string.IsNullOrWhiteSpace(pseudo) && !string.IsNullOrWhiteSpace(theme);

    protected override void OnInitialized()
    {
        themesDisponibles = GameService.GetThemesDisponibles();
        if (themesDisponibles.Any()) theme = themesDisponibles.First();
    }

    private void LancerJeu()
    {
        if (PeutLancer)
        {
            GameService.DemarrerPartie(pseudo, role, theme);
            NavManager.NavigateTo("/quiz");
        }
    }
}